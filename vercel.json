{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/swipe",      "destination": "/swipe.html" },
    { "source": "/messages",   "destination": "/messages_v2.html" },
    { "source": "/profil",     "destination": "/profil.html" },
    { "source": "/premium",    "destination": "/premium.html" },
    { "source": "/connexion",  "destination": "/connexion.html" },
    { "source": "/inscription","destination": "/inscription.html" }
  ],
  "redirects": [
    { "source": "/((?!.*\\.html$).*)", "destination": "/404.html", "statusCode": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/firebase.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
